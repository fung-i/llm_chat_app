{
  "$schema": "https://schema.tauri.app/config/2/capability-schema.json",
  "identifier": "default",
  "description": "Main window: SQL, Stronghold, shell sidecar",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "sql:default",
    "sql:allow-execute",
    "stronghold:default",
    "shell:allow-spawn"
  ]
}
